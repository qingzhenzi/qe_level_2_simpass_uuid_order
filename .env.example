# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# PostgreSQL configuration
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=password_here
PG_DBNAME=database_name

# Redis configuration
REDIS_URL=redis://:redis_password@localhost:6379
REDIS_PREFIX=app

# Deduction settings
DEDUCTION_TIMEOUT_SECS=30

# Log settings
LOG_LEVEL=info
RUST_LOG=info